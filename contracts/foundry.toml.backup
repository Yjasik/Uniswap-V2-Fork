[profile.default]
src = "src"
out = "out"
libs = ["lib"]
solc = "0.8.24"

remappings = [
    "@uniswap/v2-core/=lib/v2-core/",
    "@uniswap/v2-periphery/=lib/v2-periphery/",
    "@uniswap/lib/=lib/uniswap-lib/",
    "@openzeppelin/=lib/openzeppelin-contracts/",
    "forge-std/=lib/forge-std/src/"
]

[profile.core]
src = "lib/v2-core/contracts"
out = "out/core"
libs = ["lib"]
solc = "0.5.16"

remappings = [
    "@uniswap/v2-core/=lib/v2-core/",
    "@uniswap/lib/=lib/uniswap-lib/"
]

[profile.periphery]
src = "lib/v2-periphery/contracts"
out = "out/periphery"
libs = ["lib"]
solc = "0.6.6"

remappings = [
    "@uniswap/v2-core/=lib/v2-core/",
    "@uniswap/lib/=lib/uniswap-lib/"
]

[profile.tokens]
src = "src"
out = "out/tokens"
libs = ["lib"]
solc = "0.8.24"

remappings = [
    "@openzeppelin/=lib/openzeppelin-contracts/",
    "forge-std/=lib/forge-std/src/"
]
